# =========================================================================
# claude-code-for-pms — environment template
# Copy to .env and fill in your own values. .env is gitignored.
# Every script reads its secrets from here; nothing is hardcoded.
# =========================================================================

# --- Claude (the engine) ---------------------------------------------------
# Preferred: a Claude Code OAuth token from your Claude Max plan.
# Generate once with:  claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=
# Fallback: a metered Anthropic API key (used only if no OAuth token is set).
ANTHROPIC_API_KEY=
# Optional model / runtime overrides
CLAUDE_BIN=claude
CLAUDE_MAX_MODEL=claude-opus-4-8
CLAUDE_MAX_TIMEOUT=300
AGENT_MODEL=claude-opus-4-8
AGENT_TIMEOUT=300
AGENT_PERMISSION_MODE=acceptEdits

# --- Telegram bot ----------------------------------------------------------
# Create a bot with @BotFather, paste the token here.
AGENT_BOT_TOKEN=
# Whitelist of chat IDs allowed to talk to the bot (comma separated).
# The bot refuses to start if this is empty. Send /whoami to your bot to get it.
AGENT_ALLOWED_CHAT_IDS=
# Your name and the projects you want voice capture to recognise.
AGENT_PM_NAME=Nathan
AGENT_VOICE_PROJECTS=501,502,503

# --- Voice transcription ---------------------------------------------------
DEEPGRAM_API_KEY=

# --- Notion ----------------------------------------------------------------
NOTION_API_KEY=
NOTION_GENERAL_NOTES_DB=

# --- Monday.com ------------------------------------------------------------
# Note: the literal env name has a dot in it on the Monday side.
MONDAY.COM_API_KEY=
YOUR_TOOLBOX_BOARD_ID=
YOUR_SAFETY_AUDIT_BOARD_ID=

# --- Airtable (Day Docket / project register) ------------------------------
AIRTABLE_API_KEY=
YOUR_AIRTABLE_BASE_ID=
YOUR_DOCKET_PROJECTS_TABLE_ID=

# --- Microsoft Graph (Outlook email router / project prime) ----------------
# App-only auth (Mail.Read). Register an app in Entra ID.
TENANT_ID=
CLIENT_ID=
SECRET=

# --- Supabase (project event store) ----------------------------------------
SUPABASE_URL=
SUPABASE_API_KEY=

# --- Email out (reminders / dispatch) --------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REMINDER_EMAIL_TO=

# --- Gmail send (optional, for workflows that email via Gmail API) ---------
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- System paths ----------------------------------------------------------
# Path to a Chrome/Edge binary for HTML->PDF rendering.
CHROME_PATH=
